						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson.token) {",
									"    pm.collectionVariables.set(\"userToken\", responseJson.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
